#include <bits/stdc++.h>
using namespace std;

class Production {
public:
    string lhs;
    vector<string> rhs;

    Production(string lhs, vector<string> rhs) {
        this->lhs = lhs;
        this->rhs = rhs;
    }
};

class Item {
public:
    Production production;
    int dot;

    Item(Production production, int dot) : production(production), dot(dot) {}

    string toString() const {
        string result = production.lhs + " -> ";
        for (int i = 0; i < production.rhs.size(); i++) {
            if (i == dot) result += "• ";
            result += production.rhs[i] + " ";
        }
        if (dot == production.rhs.size()) result += "•";
        return result;
    }

    // Needed for set
    bool operator<(const Item& other) const {
        if (production.lhs != other.production.lhs)
            return production.lhs < other.production.lhs;

        if (production.rhs != other.production.rhs)
            return production.rhs < other.production.rhs;

        return dot < other.dot;
    }
};

vector<Production> grammar;

set<Item> closure(set<Item> items) {
    set<Item> result = items;
    bool changed;

    do {
        changed = false;
        set<Item> newItems;

        for (auto item : result) {
            if (item.dot < item.production.rhs.size()) {
                string symbol = item.production.rhs[item.dot];

                for (auto p : grammar) {
                    if (p.lhs == symbol) {
                        Item newItem(p, 0);
                        if (result.find(newItem) == result.end()) {
                            newItems.insert(newItem);
                            changed = true;
                        }
                    }
                }
            }
        }

        result.insert(newItems.begin(), newItems.end());

    } while (changed);

    return result;
}

set<Item> gotoSet(set<Item> items, string symbol) {
    set<Item> moved;

    for (auto item : items) {
        if (item.dot < item.production.rhs.size() &&
            item.production.rhs[item.dot] == symbol) {

            moved.insert(Item(item.production, item.dot + 1));
        }
    }

    return closure(moved);
}

int main() {
    grammar.push_back(Production("S'", {"S"}));
    grammar.push_back(Production("S", {"A", "B"}));
    grammar.push_back(Production("A", {"a"}));
    grammar.push_back(Production("B", {"b"}));

    set<Item> start;
    start.insert(Item(grammar[0], 0));

    set<Item> c = closure(start);

    cout << "Closure of start:\n";
    for (auto i : c) {
        cout << i.toString() << endl;
    }

    set<Item> g = gotoSet(c, "S");

    cout << "\nGoto on S:\n";
    for (auto i : g) {
        cout << i.toString() << endl;
    }

    return 0;
}